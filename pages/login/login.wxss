.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.logo-title {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 500rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 36rpx;
  background-color: white;
  color: #1890ff;
  border-radius: 45rpx;
  border: none;
  margin-bottom: 30rpx;
}

.login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 头像选择弹窗样式 */
.avatar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.avatar-modal-content {
  width: 600rpx;
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.avatar-modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.avatar-modal-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.avatar-modal-body {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 30rpx;
  border: 4rpx solid #1890ff;
}

.preview-avatar {
  width: 100%;
  height: 100%;
}

.avatar-tip {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.btn-choose-avatar {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #1890ff;
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.avatar-modal-footer {
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.btn-confirm {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #52c41a;
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-confirm[disabled] {
  background-color: #ccc;
}
